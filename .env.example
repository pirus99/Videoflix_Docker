# ============================================
# PROJECT CONFIGURATION
# ============================================
# Project name - used for naming routes, containers, and networks to avoid conflicts
PROJECT_NAME=videoflix

# Domain or IP address for accessing the application
# Examples: example.com, subdomain.example.com, or IP like 192.168.1.100
DOMAIN=example.com

# ============================================
# GIT REPOSITORY URLS
# ============================================
# Backend repository URL (must be publicly accessible or use credentials)
BACKEND_REPO_URL=https://github.com/yourusername/backend-repo.git
BACKEND_BRANCH=main

# Frontend repository URL
FRONTEND_REPO_URL=https://github.com/yourusername/frontend-repo.git
FRONTEND_BRANCH=main

# ============================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================
POSTGRES_DB=videoflix_db
POSTGRES_USER=videoflix_user
POSTGRES_PASSWORD=change_this_secure_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ============================================
# DJANGO BACKEND CONFIGURATION
# ============================================
# Django secret key - generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change_this_to_a_secure_random_secret_key

# Django debug mode - MUST be False in production
DEBUG=False

# Allowed hosts - comma separated list (e.g., example.com,www.example.com)
ALLOWED_HOSTS=example.com,www.example.com

# CSRF trusted origins - comma separated list with protocol
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# CORS allowed origins - comma separated list with protocol
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com

# Django superuser credentials (optional, for automatic superuser creation)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change_this_admin_password

# ============================================
# EMAIL CONFIGURATION
# ============================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@example.com

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET_KEY=change_this_to_a_secure_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# API backend URL that frontend will use
VITE_API_URL=https://example.com/api
API_BASE_URL=https://example.com/api

# ============================================
# TRAEFIK CONFIGURATION
# ============================================
# Traefik dashboard (set to false in production or protect with auth)
TRAEFIK_DASHBOARD=false

# Let's Encrypt email for SSL certificates
LETSENCRYPT_EMAIL=admin@example.com

# Traefik network name (usually no need to change)
TRAEFIK_NETWORK=traefik-public

# ============================================
# OPTIONAL: TIMEZONE
# ============================================
TZ=Europe/Berlin
